# ──────────────────────────────────────────────────────────────────────────────
# MailFlow — Environment Configuration
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in the values below
# 3. Generate the TLS cert (see README) or use --profile https for Let's Encrypt
# 4. Run:              docker compose up -d --build
# ──────────────────────────────────────────────────────────────────────────────


# ── Access ────────────────────────────────────────────────────────────────────
# Port the app listens on (HTTPS). Default is 443.
APP_PORT=443

# Port the app listens on (HTTP). Default is 80.
# Use this when running behind a reverse proxy that terminates TLS upstream.
# Your proxy should forward X-Forwarded-Proto: https so session cookies work correctly.
APP_HTTP_PORT=80

# Full URL users see in the browser — used in invite emails and CORS.
APP_URL=https://your-domain-or-ip

# GHCR image owner and version used by docker-compose.ghcr.yml.
GHCR_OWNER=xiaochou164
MAILFLOW_VERSION=latest

# Public origin used in OAuth metadata for ChatGPT custom MCP apps.
# Usually the same as APP_URL, for example: https://mail.example.com
MCP_PUBLIC_ORIGIN=

# Comma-separated public Host names accepted by the MCP server. Usually optional
# when APP_URL/MCP_PUBLIC_ORIGIN are set, but useful when serving aliases.
MCP_ALLOWED_HOSTS=


# ── Secrets ───────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
SESSION_SECRET=

# REQUIRED — generate with: openssl rand -hex 16
DB_PASSWORD=

# REQUIRED — generate with: openssl rand -hex 32
# Used to encrypt stored email credentials (passwords, OAuth tokens) at rest.
# WARNING: If this key is lost or changed, all stored credentials become unreadable
#          and users will need to re-enter passwords / re-authenticate OAuth accounts.
ENCRYPTION_KEY=

# Optional — separate HMAC secret for developer application API keys.
# Generate with: openssl rand -hex 32
# If omitted, ENCRYPTION_KEY is used with domain separation.
APPLICATION_KEY_PEPPER=

# Webhook destinations are restricted to public HTTPS hosts by default.
# Enable only for trusted self-hosted n8n instances on a private network.
WEBHOOK_ALLOW_PRIVATE_HOSTS=false


# ── Web Push Notifications (optional) ────────────────────────────────────────
# Enables native OS / PWA push notifications for new mail.
# Generate a key pair once with:  npx web-push generate-vapid-keys
# VAPID_SUBJECT must be either a mailto: address or your APP_URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com


# ── Let's Encrypt (optional — only needed with --profile https) ───────────────
# Only used when running: docker compose --profile https up -d --build
# Requires a real public domain with DNS pointing at this server.
DOMAIN=mail.yourdomain.com
ACME_EMAIL=you@yourdomain.com


# ── Experimental ──────────────────────────────────────────────────────────────
# Div-based email renderer (replaces iframe). Set to true on a dev instance to
# test before the iframe path is removed. Do not enable in production until the
# full email test matrix has been validated.
VITE_EMAIL_DIV_RENDER=false
